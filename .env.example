AXON_PRIVATE_KEY=0xyour_private_key
OTC_CONTRACT_ADDRESS=0x10063340374db851e2628D06F4732d5FF814eB34

# Contract deployment wallet. Reuse AXON_PRIVATE_KEY only if you want the same account to deploy.
DEPLOYER_PRIVATE_KEY=0xyour_deployer_private_key

# Admin and keeper for the new OTC contracts.
OTC_OWNER_ADDRESS=0xYourOwnerAddress
OTC_KEEPER_ADDRESS=0xYourKeeperAddress

# Optional deployment overrides.
AXON_CHAIN_ID=8210
BSC_CHAIN_ID=56
# OTC_CANCEL_COOLDOWN_SECONDS=900

# Filled after deployment.
# OTC_AXON_ESCROW_ADDRESS=0xYourAxonEscrowAddress
# OTC_BSC_PAYMENT_FACTORY_ADDRESS=0xYourBscPaymentFactoryAddress

AXON_RPC_URL=http://127.0.0.1:8545
BSC_RPC_URL=https://bsc-dataseed.binance.org/
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

KEEPER_URL=https://axonotc.com

# Optional overrides for token contracts if the market uses different stablecoins.
# BSC_USDT_ADDRESS=0x55d398326f99059fF775485246999027B3197955
# BSC_USDC_ADDRESS=0x8AC76a51cc950d9822D68b83fE1Ad97B32Cd580d
# ARBITRUM_USDT_ADDRESS=0xFd086bC7CD5C481DCC9C85ebe478A1C0b69FCbb9
# ARBITRUM_USDC_ADDRESS=0xaf88d065e77c8cC2239327C5EDb3A432268e5831

# Optional: point to the exact Keeper payment-info route if your deployment differs.
# OTC_KEEPER_PAYMENT_PATH=/api/v1/orders/{order_id}/payment-info
